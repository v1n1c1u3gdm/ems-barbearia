<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="010-rename-promocao-to-servico" author="ems-barbearia">
        <renameTable oldTableName="promocao" newTableName="servico"/>
        <addColumn tableName="servico">
            <column name="duracao_minutos" type="INT" defaultValueNumeric="30"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>

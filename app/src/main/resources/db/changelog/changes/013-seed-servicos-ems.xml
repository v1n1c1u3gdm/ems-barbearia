<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="013-seed-servicos-ems" author="ems-barbearia">
        <preConditions onFail="MARK_RAN">
            <rowCount tableName="servico" expectedRows="0"/>
        </preConditions>
        <insert tableName="servico">
            <column name="titulo" value="Corte"/>
            <column name="descricao" value="Corte masculino com acabamento e estilo personalizado."/>
            <column name="ativo" valueBoolean="true"/>
            <column name="duracao_minutos" valueNumeric="45"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

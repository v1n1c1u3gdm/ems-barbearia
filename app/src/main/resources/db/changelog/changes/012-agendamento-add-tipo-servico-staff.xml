<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="012-agendamento-add-tipo-servico-staff" author="ems-barbearia">
        <addColumn tableName="agendamento">
            <column name="tipo" type="VARCHAR(20)" defaultValue="FIRME">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="agendamento">
            <column name="servico_id" type="BIGINT"/>
        </addColumn>
        <addColumn tableName="agendamento">
            <column name="staff_id" type="BIGINT"/>
        </addColumn>
        <addColumn tableName="agendamento">
            <column name="data_hora_fim" type="TIMESTAMP"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="agendamento" baseColumnNames="servico_id"
            constraintName="fk_agendamento_servico" referencedTableName="servico" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="agendamento" baseColumnNames="staff_id"
            constraintName="fk_agendamento_staff" referencedTableName="staff" referencedColumnNames="id"/>
        <dropColumn tableName="agendamento" columnName="servico"/>
    </changeSet>
</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-create-configuracao-agenda" author="ems-barbearia">
        <createTable tableName="configuracao_agenda">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="slot_minutos" type="INT" defaultValueNumeric="30">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="horario_funcionamento">
            <column name="dia_semana" type="TINYINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="aberto" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="hora_inicio" type="TIME"/>
            <column name="hora_fim" type="TIME"/>
        </createTable>
        <insert tableName="configuracao_agenda">
            <column name="id" valueNumeric="1"/>
            <column name="slot_minutos" valueNumeric="30"/>
        </insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="0"/><column name="aberto" valueBoolean="false"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="1"/><column name="aberto" valueBoolean="false"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="2"/><column name="aberto" valueBoolean="true"/><column name="hora_inicio" value="09:00:00"/><column name="hora_fim" value="19:00:00"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="3"/><column name="aberto" valueBoolean="true"/><column name="hora_inicio" value="09:00:00"/><column name="hora_fim" value="19:00:00"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="4"/><column name="aberto" valueBoolean="true"/><column name="hora_inicio" value="09:00:00"/><column name="hora_fim" value="19:00:00"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="5"/><column name="aberto" valueBoolean="true"/><column name="hora_inicio" value="09:00:00"/><column name="hora_fim" value="19:00:00"/></insert>
        <insert tableName="horario_funcionamento"><column name="dia_semana" valueNumeric="6"/><column name="aberto" valueBoolean="true"/><column name="hora_inicio" value="09:00:00"/><column name="hora_fim" value="16:00:00"/></insert>
    </changeSet>
</databaseChangeLog>
